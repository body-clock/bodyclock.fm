---
import DaringLayout from '../layouts/DaringLayout.astro';
import { SITE_TITLE } from '../consts';
---

<DaringLayout title="About" description="About Patrick Perkins.">
  <h1>About</h1>

  <p>I'm Patrick Perkins, also known as Body Clock. I write about technology, music, and life.</p>

  <h2>Quick Facts</h2>
  <ul>
    <li>I build things with code, especially Ruby and Rails</li>
    <li>I make music as Body Clock</li>
    <li>I'm interested in agentic development and AI workflows</li>
    <li>I write about personal experiences, including addiction, grief, and recovery</li>
  </ul>

  <h2>Elsewhere</h2>
  <ul>
    <li><a href="https://github.com/yourusername">GitHub</a></li>
    <li><a href="https://twitter.com/yourusername">Twitter</a></li>
    <li><a href="mailto:your@email.com">Email</a></li>
  </ul>

  <h2>About This Site</h2>
  <p>
    This site is built with <a href="https://astro.build">Astro</a>. It's a place for my writing 
    and a way for people to get in touch.
  </p>
</DaringLayout>

<style>
  h1 {
    margin-bottom: var(--space-4);
  }
  
  h2 {
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
    font-size: 1.125rem;
  }
</style>
