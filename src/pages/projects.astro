---
import DaringLayout from '../layouts/DaringLayout.astro';
---

<DaringLayout title="Projects" description="Things I'm working on.">
  <h1>Projects</h1>

  <article class="project">
    <h2>Milk Crate</h2>
    <p>A tool for organizing and exploring codebases. Learning about agentic development and workflows.</p>
    <a href="https://github.com/yourusername/milkcrate">View Project →</a>
  </article>

  <article class="project">
    <h2>Body Clock (Music)</h2>
    <p>My music project. Experimental electronic music and sound design.</p>
    <a href="#">Listen →</a>
  </article>
</DaringLayout>

<style>
  h1 {
    margin-bottom: var(--space-5);
  }
  
  .project {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-6);
    border-bottom: var(--border);
  }
  
  .project:last-child {
    border-bottom: none;
  }
  
  .project h2 {
    font-size: 1.125rem;
    margin-bottom: var(--space-2);
  }
  
  .project p {
    opacity: 0.8;
    margin-bottom: var(--space-2);
  }
  
  .project a {
    font-size: var(--text-sm);
  }
</style>
