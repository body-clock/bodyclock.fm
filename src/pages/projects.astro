---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import DaringLayout from '../layouts/DaringLayout.astro';

const posts = await getCollection('pages');
const page = posts.find((p) => p.id === 'projects') as CollectionEntry<'pages'>;
const { Content } = await render(page);
---

<DaringLayout title={page.data.title} description={page.data.description}>
  <Content />
</DaringLayout>
