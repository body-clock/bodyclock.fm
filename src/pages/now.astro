---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Now - ${SITE_TITLE}`} description="What I'm currently focused on." />
  </head>
  <body>
    <Header />
    <main>
      <h1 class="display">Now</h1>
      <p>What I'm currently focused on.</p>

      <div class="now-content">
        <h2>Writing</h2>
        <p>Working on making this site a place for regular writing. Aiming for weekly posts about tech, music, and personal experiences.</p>

        <h2>Building</h2>
        <p>Milk Crate — learning about agentic development and building tools that help me think better about code.</p>

        <h2>Reading</h2>
        <ul>
          <li><em>The Creative Act</em> by Rick Rubin</li>
          <li><em>Thinking in Systems</em> by Donella H. Meadows</li>
        </ul>

        <h2>Listening</h2>
        <p>Lots of ambient and experimental electronic music. Working on new Body Clock tracks.</p>

        <p class="updated">Last updated: June 2026</p>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .now-content {
    margin-top: var(--space-xl);
  }
  
  .now-content h2 {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }
  
  .updated {
    margin-top: var(--space-16);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
