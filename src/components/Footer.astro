---
const today = new Date();
---

<footer>
  <nav class="footer-nav">
    <a href="/blog">Blog</a>
    <a href="/projects">Projects</a>
    <a href="/about">About</a>
    <a href="/now">Now</a>
    <a href="/contact">Contact</a>
  </nav>
  <p>&copy; {today.getFullYear()} Patrick Perkins</p>
</footer>

<style>
  footer {
    border-top: var(--border);
    padding: var(--space-lg) var(--gutter);
    margin-top: var(--space-3xl);
  }
  
  .footer-nav {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }
  
  .footer-nav a {
    color: var(--primary);
    text-decoration: none;
    font-size: 0.875rem;
    opacity: 0.7;
    transition: opacity 0.15s ease-out;
  }
  
  .footer-nav a:hover {
    opacity: 1;
    text-decoration: underline;
  }
  
  footer p {
    text-align: center;
    margin-bottom: 0;
    font-size: 0.875rem;
    opacity: 0.6;
  }
</style>
