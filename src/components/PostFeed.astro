---
import FormattedDate from './FormattedDate.astro';

interface Props {
  posts: Array<{
    id: string;
    data: {
      title: string;
      date: Date;
      description?: string;
    };
  }>;
  showExcerpts?: boolean;
}

const { posts, showExcerpts = false } = Astro.props;
---

<div class="post-feed">
  {posts.map((post) => (
    <article class="post-item">
      <h2>
        <a href={`/blog/${post.id}/`}>{post.data.title}</a>
      </h2>
      <h6 class="post-date">
        <FormattedDate date={post.data.date} />
      </h6>
      {showExcerpts && post.data.description && (
        <p class="post-excerpt">{post.data.description}</p>
      )}
    </article>
  ))}
</div>

<style>
  .post-feed {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  
  .post-item {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  
  .post-item h2 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0;
    line-height: 1.4;
  }
  
  .post-item h2 a {
    color: var(--color-text);
    text-decoration: none;
  }
  
  .post-item h2 a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  
  .post-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin: 0;
    font-weight: 400;
  }
  
  .post-excerpt {
    margin-top: var(--space-2);
    margin-bottom: 0;
    font-size: var(--text-sm);
    opacity: 0.7;
  }
</style>
