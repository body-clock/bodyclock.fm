---
// Custom subscribe modal - uses our Cloudflare Worker API
---

<div id="subscribe-modal" class="modal" aria-hidden="true">
  <div class="modal-backdrop"></div>
  <div class="modal-content">
    <button class="modal-close" aria-label="Close">&times;</button>
    <h3>Stay in the loop</h3>
    <p>Get notified when I publish something new.</p>
    <form class="subscribe-form" id="subscribe-form">
      <input type="email" name="email" placeholder="your@email.com" required />
      <button type="submit">Subscribe</button>
    </form>
    <p class="subscribe-success" style="display: none;">Thanks! You're subscribed.</p>
    <p class="subscribe-note">No spam. Unsubscribe anytime.</p>
  </div>
</div>

<style>
  .modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }
  
  .modal[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }
  
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
  }
  
  .modal-content {
    position: relative;
    background: var(--color-bg);
    border: var(--border);
    border-radius: var(--border-radius);
    padding: var(--space-8);
    max-width: 28rem;
    width: calc(100% - var(--gutter-mobile) * 2);
    text-align: center;
  }
  
  .modal-close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    font-size: 1.5rem;
    color: var(--color-text-muted);
    line-height: 1;
    padding: var(--space-1);
  }
  
  .modal-close:hover {
    color: var(--color-text);
  }
  
  .modal-content h3 {
    margin-bottom: var(--space-2);
  }
  
  .modal-content > p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }
  
  .subscribe-form {
    display: flex;
    gap: var(--space-2);
  }
  
  .subscribe-form input {
    flex: 1;
    padding: var(--space-2) var(--space-3);
    border: var(--border);
    border-radius: var(--border-radius);
    background: var(--color-surface);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-family: inherit;
  }
  
  .subscribe-form input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  
  .subscribe-form button {
    padding: var(--space-2) var(--space-4);
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: var(--border-radius);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
  }
  
  .subscribe-form button:hover {
    opacity: 0.9;
  }
  
  .subscribe-success {
    color: var(--color-accent);
    font-weight: 600;
  }
  
  .subscribe-note {
    font-size: var(--text-xs) !important;
    opacity: 0.6;
    margin-top: var(--space-3) !important;
    margin-bottom: 0 !important;
  }
  
  @media (max-width: 640px) {
    .subscribe-form {
      flex-direction: column;
    }
  }
</style>

<script>
  function openModal() {
    const modal = document.getElementById('subscribe-modal');
    if (modal) {
      modal.setAttribute('aria-hidden', 'false');
      modal.querySelector('input')?.focus();
    }
  }
  
  function closeModal() {
    const modal = document.getElementById('subscribe-modal');
    if (modal) {
      modal.setAttribute('aria-hidden', 'true');
    }
  }
  
  // Handle form submission
  document.getElementById('subscribe-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const email = (form.querySelector('input[name="email"]') as HTMLInputElement)?.value;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    
    submitBtn.textContent = 'Subscribing...';
    submitBtn.disabled = true;
    
    try {
      const response = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      
      const data = await response.json();
      
      if (response.ok) {
        form.style.display = 'none';
        const note = form.parentElement?.querySelector('.subscribe-note');
        if (note) note.style.display = 'none';
        const success = form.parentElement?.querySelector('.subscribe-success');
        if (success) success.style.display = 'block';
      } else {
        submitBtn.textContent = 'Subscribe';
        submitBtn.disabled = false;
        alert(data.error || 'Something went wrong');
      }
    } catch (err) {
      submitBtn.textContent = 'Subscribe';
      submitBtn.disabled = false;
      alert('Network error. Please try again.');
    }
  });
  
  // Open triggers
  document.querySelectorAll('[data-subscribe]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      openModal();
    });
  });
  
  // Close triggers
  document.querySelector('.modal-backdrop')?.addEventListener('click', closeModal);
  document.querySelector('.modal-close')?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
  
  // Expose for external triggers
  (window as any).openSubscribeModal = openModal;
</script>
