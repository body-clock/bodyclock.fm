---
const currentPath = Astro.url.pathname;
---

<aside class="sidebar">
  <p class="author">By <strong>Patrick Perkins</strong></p>
  
  <nav class="sidebar-nav">
    <a href="/blog" class={currentPath.startsWith('/blog') ? 'current' : ''}>Blog</a>
    <a href="/projects" class={currentPath === '/projects' ? 'current' : ''}>Projects</a>
    <a href="/about" class={currentPath === '/about' ? 'current' : ''}>About</a>
    <a href="/now" class={currentPath === '/now' ? 'current' : ''}>Now</a>
    <a href="/contact" class={currentPath === '/contact' ? 'current' : ''}>Contact</a>
  </nav>
</aside>

<style>
  .sidebar {
    width: 120px;
    flex-shrink: 0;
    padding-top: var(--space-2);
  }
  
  .author {
    font-size: var(--text-sm);
    margin-bottom: var(--space-5);
    line-height: 1.4;
    opacity: 0.8;
  }
  
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  
  .sidebar-nav a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    opacity: 0.7;
    display: block;
  }
  
  .sidebar-nav a:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  
  .sidebar-nav a.current {
    opacity: 1;
    font-weight: 600;
  }
</style>
