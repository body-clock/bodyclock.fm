---
import { navLinks } from '../data/navigation';
const currentPath = Astro.url.pathname;
---

<aside class="sidebar">
  <p class="author">By <a href="/" class={currentPath === '/' ? 'current' : ''}>Patrick Perkins</a></p>
  
  <nav class="sidebar-nav">
    {navLinks.map((link) => (
      <a href={link.href} class={currentPath.startsWith(link.href) ? 'current' : ''}>{link.label}</a>
    ))}
  </nav>

  <button class="subscribe-btn" data-subscribe>Subscribe</button>
</aside>

<style>
  .sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    padding-top: 0;
    border-right: var(--border);
    padding-right: var(--space-8);
  }
  
  @media (max-width: 640px) {
    .sidebar {
      display: none;
    }
  }
  
  .author {
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
    line-height: 1.4;
    opacity: 0.8;
    white-space: nowrap;
  }
  
  .author a {
    color: var(--color-text);
    text-decoration: none;
  }
  
  .author a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  
  .author a.current {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  
  .subscribe-btn {
    margin-top: var(--space-8);
    padding: var(--space-2) var(--space-4);
    background: transparent;
    color: var(--color-text-muted);
    border: var(--border);
    border-radius: var(--border-radius);
    font-size: var(--text-xs);
    cursor: pointer;
    font-family: inherit;
    width: 100%;
    text-align: center;
  }
  
  .subscribe-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-end;
  }
  
  .sidebar-nav a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    opacity: 0.7;
    display: block;
  }
  
  .sidebar-nav a:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  
  .sidebar-nav a.current {
    opacity: 1;
    font-weight: 600;
  }
</style>
