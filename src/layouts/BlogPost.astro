---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import DaringLayout from './DaringLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, date, updatedDate, tags, heroImage } = Astro.props;

const blogSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description: description,
	datePublished: date.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	author: {
		'@type': 'Person',
		name: 'Patrick Perkins',
		url: 'https://bodyclock.fm',
	},
};
---

<DaringLayout title={title} description={description} schema={blogSchema}>
  <article>
    <header class="post-header">
      <h1>{title}</h1>
      <h6 class="post-date">
        <FormattedDate date={date} />
        {updatedDate && (
          <span class="updated"> (updated <FormattedDate date={updatedDate} />)</span>
        )}
      </h6>
    </header>

    {heroImage && (
      <div class="hero-image">
        <Image width={1020} height={510} src={heroImage} alt="" />
      </div>
    )}

    <div class="prose">
      <slot />
    </div>

    {tags && tags.length > 0 && (
      <div class="post-tags">
        {tags.map((tag) => (
          <a href={`/tags/${tag}/`} class="tag">#{tag}</a>
        ))}
      </div>
    )}
  </article>
</DaringLayout>

<style>
  .post-header {
    margin-bottom: var(--space-6);
  }
  
  .post-header h1 {
    margin-bottom: var(--space-2);
  }
  
  .post-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin: 0;
    font-weight: 400;
  }
  
  .updated {
    font-style: italic;
  }
  
  .hero-image {
    margin-bottom: var(--space-6);
  }
  
  .hero-image img {
    width: 100%;
  }
  
  .prose {
    line-height: var(--leading-relaxed);
  }
  
  .post-tags {
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: var(--border);
  }
  
  .tag {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    margin-right: var(--space-3);
  }
  
  .tag:hover {
    text-decoration: underline;
  }
</style>
